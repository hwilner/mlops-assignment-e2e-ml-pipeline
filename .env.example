# .env.example — copy to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Required: Nebius inference API key for mini-swe-agent
# ---------------------------------------------------------------------------
NEBIUS_API_KEY=XXX

# ---------------------------------------------------------------------------
# Airflow (only needed for docker-compose deployment)
# ---------------------------------------------------------------------------
# Generate a Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# Change this to a strong random string in production.
AIRFLOW__WEBSERVER__SECRET_KEY=changeme-in-production

# ---------------------------------------------------------------------------
# MLflow tracking server
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=/mlflow/artifacts

# ---------------------------------------------------------------------------
# Optional: S3 / Object Storage for remote artefact upload
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET=your-mlops-bucket

# ---------------------------------------------------------------------------
# mini-swe-agent cost tracking
# ---------------------------------------------------------------------------
MSWEA_COST_TRACKING=ignore_errors
